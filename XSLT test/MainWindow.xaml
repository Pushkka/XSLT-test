<Window
    x:Class="XSLT_test.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:XSLT_test"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Window.Resources>
        <ObjectDataProvider
            x:Key="MonthValues"
            MethodName="GetValues"
            ObjectType="{x:Type system:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="local:Month" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="10" Orientation="Horizontal">
            <ui:Button
                x:Name="FileSelector"
                Width="178"
                VerticalAlignment="Top"
                Click="FileSelector_Click"
                Content="Выбрать XML файл" />
            <Label
                Margin="20,0,0,0"
                VerticalAlignment="Center"
                Content="{Binding OpenedFile}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="10">
                <ItemsControl x:Name="EmployeesTreeView" d:ItemsSource="{d:SampleData ItemCount=2}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="2" IsExpanded="False">
                                <Expander.Header>
                                    <StackPanel Margin="5,0" Orientation="Horizontal">
                                        <ui:Button
                                            VerticalAlignment="Stretch"
                                            Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                            <ui:SymbolIcon Symbol="Delete12" />
                                        </ui:Button>
                                        <ui:TextBox
                                            Width="120"
                                            Margin="5,0,5,0"
                                            FontWeight="Bold"
                                            PlaceholderText="Имя"
                                            Text="{Binding Name}" />
                                        <ui:TextBox
                                            Width="120"
                                            Margin="5,0,5,0"
                                            PlaceholderText="Фамилия"
                                            Text="{Binding Surname}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="Gray"
                                            Text="{Binding TotalSalary, StringFormat='(Всего: {0})'}" />
                                    </StackPanel>
                                </Expander.Header>
                                <Expander.Content>
                                    <StackPanel Margin="20,0,0,5">
                                        <ItemsControl ItemsSource="{Binding Salaries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,2" Orientation="Horizontal">
                                                        <ui:Button
                                                            VerticalAlignment="Stretch"
                                                            Command="{Binding DataContext.DeleteSalaryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                            <ui:SymbolIcon Symbol="Delete12" />
                                                        </ui:Button>
                                                        <ComboBox
                                                            Width="150"
                                                            VerticalAlignment="Center"
                                                            ItemsSource="{Binding Source={StaticResource MonthValues}}"
                                                            SelectedItem="{Binding Month}" />
                                                        <TextBox
                                                            Width="150"
                                                            Margin="5,0,0,0"
                                                            Foreground="DarkGreen"
                                                            Text="{Binding Amount}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ui:Button
                                            VerticalAlignment="Stretch"
                                            Command="{Binding DataContext.AddSalaryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Content="Добавить запись" />
                                    </StackPanel>
                                </Expander.Content>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ui:Button
                    VerticalAlignment="Stretch"
                    Command="{Binding AddEmployeeCommand}"
                    Content="Добавить сотрудника" />
            </StackPanel>
        </ScrollViewer>

        <ui:Button
            x:Name="Save"
            Grid.Row="2"
            Width="178"
            Margin="10"
            VerticalAlignment="Top"
            Command="{Binding SaveCommand}"
            Content="Сохранить" />
    </Grid>
</Window>
